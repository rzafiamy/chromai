{
  "manifest_version": 3,
  "name": "ChromAI - Browser Copilot",
  "version": "1.1.0",
  "description": "AI agent copilot that reads, understands and interacts with web pages.",

  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "microphone"
  ],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "side_panel": {
    "default_path": "public/sidebar.html"
  },

  "options_ui": {
    "page": "public/settings.html",
    "open_in_tab": true
  },

  "action": {
    "default_title": "Open ChromAI",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
